<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Drones IPC2 "Proyecto 2" </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f0f4f8;
        }
        .navbar {
            background: linear-gradient(90deg, #1a1a2e, #16213e);
        }
        .navbar-brand, .nav-link {
            color: #00d4ff !important;
        }
        .nav-link:hover {
            color: #ffffff !important;
        }
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-4px);
        }
        .footer {
            background: #1a1a2e;
            color: #aaa;
            text-align: center;
            padding: 12px;
            margin-top: 40px;
        }
        h2 {
            color: #1a1a2e;
            font-weight: bold;
        }
        .table thead {
            background: #1a1a2e;
            color: white;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                 Sistema Drones IPC2
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"> Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="CargarXML"> Cargar XML</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="GenerarXML"> Generar XML</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Drones"> Drones</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="SistemasDrones"> Sistemas</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Mensajes"> Mensajes</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Ayuda"> Ayuda</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" asp-controller="Home" asp-action="Inicializar"
                           onclick="return confirm('Reiniciar sistema?')"> Inicializar</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <div class="footer">
        <p class="mb-0">Sistema de Drones Encriptados por Bily Folgar; 2026 1S - IPC2 USAC</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>