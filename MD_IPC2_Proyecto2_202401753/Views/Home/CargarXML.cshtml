@{
    ViewData["Title"] = "Cargar XML";
}
<div class="container mt-4">
    <h2> Cargar Archivo XML</h2>
    <hr />
    <form method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <label class="form-label">Selecciona el archivo XML de entrada:</label>
            <input type="file" name="archivo" accept=".xml" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Cargar XML</button>
        <a href="/" class="btn btn-secondary">Volver</a>
    </form>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-info mt-3">
            @ViewBag.Mensaje
        </div>
    }
</div>