@using MD_IPC2_Proyecto2_202401753.Models.Entidades
@using MD_IPC2_Proyecto2_202401753.Models.TDA
@{
    ViewData["Title"] = "Sistemas de Drones";
    ListaEnlazada lista = ViewBag.Lista;
}
<div class="container mt-4">
    <h2>🛸 Sistemas de Drones</h2>
    <hr />

    @if (lista == null || lista.EstaVacia())
    {
        <p class="text-muted">No hay sistemas de drones registrados.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Altura Máxima</th>
                    <th>Cantidad Drones</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @{
                    Nodo actual = lista.ObtenerCabeza();
                    while (actual != null)
                    {
                        SistemaDrones s = (SistemaDrones)actual.Dato;
                        <tr>
                            <td>@s.Nombre</td>
                            <td>@s.AlturaMaxima m</td>
                            <td>@s.CantidadDrones</td>
                            <td>
                                <a href="/Home/VisualizarSistema?nombre=@s.Nombre"
                                   class="btn btn-sm btn-info">
                                    Ver Graphviz
                                </a>
                            </td>
                        </tr>
                        actual = actual.Siguiente;
                    }
                }
            </tbody>
        </table>
    }
    <a href="/" class="btn btn-secondary">Volver</a>
</div>