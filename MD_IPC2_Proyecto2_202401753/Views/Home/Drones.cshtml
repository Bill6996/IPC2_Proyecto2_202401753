@using MD_IPC2_Proyecto2_202401753.Models.Entidades
@using MD_IPC2_Proyecto2_202401753.Models.TDA
@{
    ViewData["Title"] = "Gestión de Drones";
    ListaEnlazada lista = ViewBag.Lista;
}
<div class="container mt-4">
    <h2>🚁 Gestión de Drones</h2>
    <hr />

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <h4>Agregar nuevo dron</h4>
    <form method="post" action="/Home/AgregarDron" class="row g-2 mb-4">
        <div class="col-auto">
            <input type="text" name="nombre" class="form-control" placeholder="Nombre del dron" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Agregar</button>
        </div>
    </form>

    <h4>Listado de Drones (orden alfabético)</h4>
    @if (lista == null || lista.EstaVacia())
    {
        <p class="text-muted">No hay drones registrados.</p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr><th>#</th><th>Nombre del Dron</th></tr>
            </thead>
            <tbody>
                @{
                    Nodo actual = lista.ObtenerCabeza();
                    int i = 1;
                    while (actual != null)
                    {
                        Dron d = (Dron)actual.Dato;
                        <tr>
                            <td>@i</td>
                            <td>@d.Nombre</td>
                        </tr>
                        actual = actual.Siguiente;
                        i++;
                    }
                }
            </tbody>
        </table>
    }
    <a href="/" class="btn btn-secondary">Volver</a>
</div>