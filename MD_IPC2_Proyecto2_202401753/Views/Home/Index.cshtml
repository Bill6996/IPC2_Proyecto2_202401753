@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold" style="color:#1a1a2e"> Sistema de Drones Encriptados</h1>
    <p class="lead text-muted">Universidad San Carlos de Guatemala — Introducción a la Programación y Computación 2</p>
    <hr />
</div>

<div class="row g-4">
    <div class="col-md-4">
        <a href="/Home/CargarXML" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#1a1a2e,#16213e)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Cargar XML</h5>
                    <p class="small opacity-75">Carga el archivo de configuración inicial</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Home/GenerarXML" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#11998e,#38ef7d)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Generar XML</h5>
                    <p class="small opacity-75">Genera el archivo de salida con resultados</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Home/Drones" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#f7971e,#ffd200)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Drones</h5>
                    <p class="small opacity-75">Ver y agregar drones al sistema</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Home/SistemasDrones" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#355c7d,#6c5b7b)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Sistemas de Drones</h5>
                    <p class="small opacity-75">Visualiza sistemas con Graphviz</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Home/Mensajes" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#c0392b,#e74c3c)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Mensajes</h5>
                    <p class="small opacity-75">Ver mensajes e instrucciones detalladas</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="/Home/Ayuda" class="text-decoration-none">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#2c3e50,#4ca1af)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Ayuda</h5>
                    <p class="small opacity-75">Información del estudiante y documentación</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="/Home/Inicializar" class="text-decoration-none"
           onclick="return confirm('¿Estás seguro? Se borrarán todos los datos.')">
            <div class="card text-white h-100" style="background:linear-gradient(135deg,#636363,#a2ab58)">
                <div class="card-body text-center py-4">
                    <div style="font-size:3rem"></div>
                    <h5 class="mt-2">Inicializar</h5>
                    <p class="small opacity-75">Reinicia el sistema borrando todos los datos</p>
                </div>
            </div>
        </a>
    </div>

</div>